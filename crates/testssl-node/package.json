{
  "name": "testssl-node",
  "version": "0.1.0",
  "description": "Node.js bindings for testssl-rs — TLS/SSL testing library (Rust port of testssl.sh)",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/testssl/testssl-rs.git",
    "directory": "crates/testssl-node"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "jest",
    "test:integration": "TESTSSL_INTEGRATION=1 jest",
    "prepublishOnly": "echo 'Use CI/CD pipeline to publish. Run npm run build manually if needed.'"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 60000
  },
  "keywords": [
    "tls",
    "ssl",
    "security",
    "testssl",
    "scanner",
    "napi",
    "rust"
  ],
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "jest": "^29.0.0"
  },
  "engines": {
    "node": ">= 16"
  },
  "napi": {
    "name": "testssl-node",
    "triples": {
      "defaults": true,
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-unknown-linux-musl"
      ]
    }
  },
  "license": "AGPL-3.0",
  "files": [
    "index.js",
    "index.d.ts",
    "*.node"
  ]
}
